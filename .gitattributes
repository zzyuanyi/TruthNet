# TruthNet — Git 属性配置
# 统一换行符 LF，避免跨平台 CRLF/LF 混用问题
* text=auto eol=lf

# 文本文件强制 LF
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf
*.env.example text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig text eol=lf

# 二进制文件（禁止换行符转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.parquet binary
*.pkl binary
*.bin binary
*.pt binary
*.pth binary
*.onnx binary
*.safetensors binary
*.xlsx binary
*.xls binary
*.docx binary
*.pptx binary
*.zip binary
*.tar.gz binary
*.whl binary
