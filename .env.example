# TruthNet 环境变量模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ===== 应用 =====
APP_NAME=TruthNet
APP_ENV=development
DEBUG=true

# ===== 服务端口 =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ===== LLM 配置 =====
# 不要在此填写真实 API Key，仅通过本机 .env 或环境变量注入
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# ===== 嵌入模型 =====
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# ===== 数据库 =====
SQLITE_PATH=data/truthnet.db

# ===== ChromaDB =====
CHROMA_PERSIST_DIR=data/chroma_db

# ===== 日志 =====
LOG_LEVEL=INFO
