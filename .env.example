# TruthNet 环境变量模板 (V12 baseline · 2026-07-17)
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ===== Profile =====
# lite: SQLite + NetworkX + ChromaDB local + Mock LLM (默认开发/CI)
# full: MySQL + Neo4j + ChromaDB persistent + DeepSeek/Qwen
TRUTHNET_PROFILE=lite

# ===== 应用 =====
APP_NAME=TruthNet
APP_ENV=development
DEBUG=true

# ===== 服务端口 =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ===== 数据库后端 =====
# lite: sqlite | full: mysql
SQL_BACKEND=sqlite
SQLITE_PATH=data/truthnet.db

# MySQL（仅 full profile）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=truthnet
MYSQL_USER=truthnet
MYSQL_PASSWORD=

# ===== 图数据库后端 =====
# lite: networkx | full: neo4j
GRAPH_BACKEND=networkx

# Neo4j（仅 full profile）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ===== 向量数据库 =====
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=data/chroma_db

# ===== LLM Provider =====
# lite: mock | full: deepseek | qwen
LLM_BACKEND=mock

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Qwen（通义千问）
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen-max

# LLM 回退、重试与超时
LLM_FALLBACK_BACKEND=
LLM_RETRY_MAX_ATTEMPTS=2
LLM_RETRY_MIN_WAIT=1.0
LLM_RETRY_MAX_WAIT=5.0
LLM_REQUEST_TIMEOUT=30

# ===== 嵌入模型 =====
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ===== 数据流水线 =====
DATA_ROOT=data/raw
PROCESSED_DATA_DIR=data/processed
EMBEDDING_MODEL_LOCAL=BAAI/bge-small-zh-v1.5
EMBEDDING_CACHE_DIR=data/model_cache

# ===== API 版本控制 =====
API_V1_ENABLED=true
LEGACY_API_ENABLED=true

# ===== 数据版本 =====
DEFAULT_AS_OF=
DATASET_VERSION=mock-v12
RULE_SET_VERSION=finance-rules-1.0.0
GRAPH_VERSION=equity-mock-v12

# ===== 日志 =====
LOG_LEVEL=INFO
